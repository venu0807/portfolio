# Vite Environment Variables Example
# Copy this file to .env.local and fill in your values

# Vite (client-side env vars must be prefixed with VITE_)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_ANALYTICS_ENDPOINT=https://your-analytics-endpoint.com

# Supabase (if using client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API URLs (if different from relative paths)
VITE_API_URL=https://api.example.com